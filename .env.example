# Copie este arquivo para .env.local e preencha os valores reais antes de publicar.

# URL pública do site (usada em metadata, sitemap, Open Graph e JSON-LD).
NEXT_PUBLIC_SITE_URL="https://www.vilelacordeiro.adv.br"

# --- Integração do formulário de contato (opcional, ver CONTENT_PENDING.md) ---
# O endpoint /api/contact hoje apenas valida os dados e registra em log.
# Para enviar e-mails de verdade, integre um provedor (ex: Resend, SendGrid)
# e defina as variáveis abaixo de acordo com o provedor escolhido.
# RESEND_API_KEY=""
# CONTACT_FORM_TO_EMAIL="contato@vilelacordeiro.adv.br"

# --- Analytics (opcional) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=""
